{
  "AllowedHosts": "*",

  "NLog": {
    // yg added 20230320
    "throwConfigExceptions": true,
    "internalLogLevel": "Info",
    "internalLogFile": "${basedir}/ProjectLogs/internal-nlog.log",
    "targets": {
      "async": true,
      "business-log": {
        "type": "File",
        "fileName": "${basedir}/ProjectLogs/${date:format=yyyy-MM}/${processname}-business-${shortdate}.log",
        "archiveFileName": "${basedir}/ProjectLogs/${date:format=yyyy-MM}/${processname}-business-${shortdate}-archive-{#####}.log",
        "maxArchiveFiles": "90",
        "archiveAboveSize": "20971520",
        "layout": "[${uppercase:${level}}]${longdate}|traceId: ${aspnet-TraceIdentifier}|${event-properties:item=EventId_Id:whenEmpty=0}|${logger}|${message}${onexception:${newline}${exception:format=tostring,message,method:maxInnerExceptionLevel=5:innerFormat=tostring,message,method}}"
      },
      "request-log": {
        "type": "File",
        "fileName": "${basedir}/ProjectLogs/${date:format=yyyy-MM}/${processname}-request-${shortdate}.log",
        "archiveFileName": "${basedir}/ProjectLogs/${date:format=yyyy-MM}/${processname}-request-${shortdate}-archive-{#####}.log",
        "maxArchiveFiles": "90",
        "archiveAboveSize": "20971520",
        "layout": "[${uppercase:${level}}]${longdate}|traceId: ${aspnet-TraceIdentifier}|${event-properties:item=EventId:whenEmpty=0}|${message}${onexception:${newline}${exception:format=tostring,message,method:maxInnerExceptionLevel=5:innerFormat=tostring,message,method}}"
      },
      "console-log": {
        "type": "ColoredConsole",
        "layout": "${MicrosoftConsoleLayout}",
        "rowHighlightingRules": [
          {
            "condition": "level >= LogLevel.Error",
            "foregroundColor": "Red"
          },
          {
            "condition": "level == LogLevel.Fatal",
            "foregroundColor": "Red",
            "backgroundColor": "White"
          }
        ]
      }
    },
    "rules": [
      {
        "logger": "Microsoft.Hosting.Lifetime",
        "minLevel": "Info",
        "writeTo": "console-log, business-log",
        "final": true
      },
      {
        // Microsoft.AspNetCore.Hosting.Diagnostics 与 Microsoft.AspNetCore.HttpLogging 可以考虑二选一
        // 其中 HttpLogging 需要在 Program 中配置，详见 https://learn.microsoft.com/en-us/aspnet/core/fundamentals/http-logging/
        // HttpLogging 配置已在 Program 中存在，如需使用可将下文及 Program 中注释解除
        "logger": "Microsoft.AspNetCore.Hosting.Diagnostics",
        "minLevel": "Info",
        "writeTo": "request-log",
        "final": true
      },
      // {
      //   "logger": "Microsoft.AspNetCore.HttpLogging",
