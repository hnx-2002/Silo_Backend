{
  "name": "ptools_psilofrontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "preinstall": "only-allow pnpm",
    "dev": "vite --mode frontLocal --base=/PTools_PSilo/",
    "devhost": "vite --host --mode frontLocal  --base=/PTools_PSilo/",
    "builddev": "vue-tsc -b && vite build --mode builddev --base=/PTools_PSilo/",
    "buildpro": "vue-tsc -b && vite build --mode buildpro --base=/PTools_PSilo/",
    "buildstg": "vue-tsc -b && vite build --mode buildstg --base=/PTools_PSilo/",
    "serve": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.26",
    "@js-preview/docx": "^1.6.4",
    "@js-preview/excel": "^1.7.14",
    "@microsoft/signalr": "^8.0.17",
    "@vicons/ionicons5": "^0.13.0",
    "@vicons/material": "^0.13.0",
    "crypto-js": "^4.2.0",
    "hls.js": "^1.6.15",
    "moment": "^2.30.1",
    "pdfjs-dist": "^5.4.449",
    "pinia": "^3.0.4",
    "vue-element-plus-x": "^1.3.7",
    "vue-i18n": "^11.2.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.2",
    "naive-ui": "^2.43.2",
    "only-allow": "^1.2.2",
    "sass": "^1.94.2",
    "vfonts": "^0.0.3"
  }
}

