{
  // 项目根目录的 TypeScript 主配置文件
  // 使用 TypeScript 项目引用（Project References）组织多个子项目
  // 不直接编译任何文件
  "files": [],
  // 引用其他 TypeScript 子项目配置
  "references": [
    {
      "path": "./tsconfig/tsconfig.app.json"
    }, // 应用程序源代码配置
    {
      "path": "./tsconfig/tsconfig.node.json"
    } // Node.js 环境配置
  ]
}
