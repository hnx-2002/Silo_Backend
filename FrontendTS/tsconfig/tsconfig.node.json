{
  // Node.js 环境的 TypeScript 配置文件
  // 用于处理项目中在 Node.js 环境下运行的代码（如配置文件）
  "compilerOptions": {
    // TypeScript 构建信息文件路径，用于加速增量编译
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.node.tsbuildinfo",
    // 目标 JavaScript 版本：ES2023
    "target": "ES2023",
    // 包含的标准库：ES2023
    "lib": ["ES2023"],
    // 模块系统：ESNext（最新的 ECMAScript 模块规范）
    "module": "ESNext",
    // 引入 Node.js 类型定义
    "types": ["node"],
    // 跳过对声明文件的类型检查，提高编译速度
    "skipLibCheck": true,

    /* 打包工具模式配置 */
    // 模块解析策略：bundler（适合 Vite 等现代打包工具）
    "moduleResolution": "bundler",
    // 允许直接导入 .ts 文件扩展名
    "allowImportingTsExtensions": true,
    // 使用精确的模块语法
    "verbatimModuleSyntax": true,
    // 强制检测模块
    "moduleDetection": "force",
    // 不生成编译输出文件（仅用于类型检查）
    "noEmit": true,

    /* 严格类型检查选项 */
    // 启用所有严格类型检查选项
    "strict": true,
    // 不允许未使用的局部变量
    "noUnusedLocals": true,
    // 不允许未使用的参数
    "noUnusedParameters": true,
    // 仅对可擦除的语法进行类型检查
    "erasableSyntaxOnly": true,
    // 不允许 switch 语句中的 case 穿透
    "noFallthroughCasesInSwitch": true,
    // 检查有副作用的导入语句
    "noUncheckedSideEffectImports": true
  },
  // 包含需要编译的文件：主要是 Vite 配置文件
  "include": ["../vite.config.ts"]
}
