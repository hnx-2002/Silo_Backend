{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "htmlWhitespaceSensitivity": "ignore",
  "vueIndentScriptAndStyle": false,
  "endOfLine": "auto",
  "overrides": [
    {
      "files": "*.ts",
      "parser": "typescript"
    },
    {
      "files": "*.vue",
      "parser": "vue"
    },
    {
      "files": "*.json",
      "parser": "json"
    },
    {
      "files": "*.jsonc",
      "parser": "jsonc"
    }
  ]
}
